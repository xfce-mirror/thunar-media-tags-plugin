msgstr "ບໍ່ຮູ້ຈັກສິລະປິນ"

#: ../thunar-plugin/tag-renamer.c:474 ../thunar-plugin/audio-tags-page.c:209
msgid "Unknown Title"
msgstr "ບໍ່ຮູ້ຈັກຊື່ເພງ"

