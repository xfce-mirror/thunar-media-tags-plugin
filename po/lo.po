msgstr "ສິລະປິນ - ລຳດັບ - ຊື່ເພງ"

#: ../thunar-plugin/tag-renamer.c:67
msgid "Custom"
msgstr "ກຳນົດເອງ"

#. Custom format
#: ../thunar-plugin/tag-renamer.c:243
msgid "Cust_om format:"
msgstr "ຮູບແບບກຳນົດເ_ອງ:"

#. Format label
#: ../thunar-plugin/tag-renamer.c:272
msgid "_Format:"
msgstr "ຮູບແ_ບບ:"

#: ../thunar-plugin/tag-renamer.c:314
msgid "_Underscores"
msgstr "ຂີດ_ກ້ອງ"

#: ../thunar-plugin/tag-renamer.c:316
msgid ""
"Activating this option will replace all spaces in the target filename with "
"underscores."
msgstr "ການເປີດໃຊ້ຕົວເລືອກນີ້ຈະປ່ຽນທຸກບ່ອນວ່າງໃນຊື່ໄຟລ໌ເປົ້າໝາຍໃຫ້ເປັນຂີດກ້ອງ."

#: ../thunar-plugin/tag-renamer.c:321
msgid "_Lowercase"
msgstr "ຕົວພິມ_ນ້ອຍ"

#: ../thunar-plugin/tag-renamer.c:323
msgid ""
"If you activate this, the resulting filename will only contain lowercase "
"letters."
msgstr "ຫາກທ່ານເປີດໃຊ້ສິ່ງນີ້, ຊື່ໄຟລ໌ທີ່ໄດ້ຈະມີພຽງແຕ່ຕົວພິມນ້ອຍເທົ່ານັ້ນ."

#: ../thunar-plugin/tag-renamer.c:466 ../thunar-plugin/audio-tags-page.c:183
