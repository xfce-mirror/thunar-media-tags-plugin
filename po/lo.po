#: ../thunar-plugin/audio-tags-page.c:328
msgid "<b>Track:</b>"
msgstr "<b>ລຳດັບ:</b>"

#: ../thunar-plugin/audio-tags-page.c:338
msgid "Enter the track number here."
msgstr "ປ້ອນລຳດັບເພງທີ່ນີ້."

#: ../thunar-plugin/audio-tags-page.c:347
msgid "<b>Year:</b>"
msgstr "<b>ປີ:</b>"

#: ../thunar-plugin/audio-tags-page.c:357
msgid "Enter the release year here."
msgstr "ປ້ອນປີທີ່ອອກທີ່ນີ້."

#: ../thunar-plugin/audio-tags-page.c:366
msgid "<b>Artist:</b>"
msgstr "<b>ສິລະປິນ:</b>"

#: ../thunar-plugin/audio-tags-page.c:373
msgid "Enter the name of the artist or author of this file here."
msgstr "ປ້ອນຊື່ສິລະປິນ ຫຼື ຜູ້ແຕ່ງໄຟລ໌ນີ້ທີ່ນີ້."

#: ../thunar-plugin/audio-tags-page.c:382
msgid "<b>Title:</b>"
msgstr "<b>ຊື່ເພງ:</b>"

#: ../thunar-plugin/audio-tags-page.c:389
msgid "Enter the song title here."
msgstr "ປ້ອນຊື່ເພງທີ່ນີ້."

#: ../thunar-plugin/audio-tags-page.c:397
msgid "<b>Album:</b>"
msgstr "<b>ອັລບັ້ມ:</b>"

#: ../thunar-plugin/audio-tags-page.c:404
msgid "Enter the album/record title here."
msgstr "ປ້ອນຊື່ອັລບັ້ມ/ຊຸດເພງທີ່ນີ້."

#: ../thunar-plugin/audio-tags-page.c:412
msgid "<b>Comment:</b>"
msgstr "<b>ຄຳເຫັນ:</b>"

#: ../thunar-plugin/audio-tags-page.c:419
msgid "Enter your comments here."
msgstr "ປ້ອນຄຳເຫັນຂອງທ່ານທີ່ນີ້."

#: ../thunar-plugin/audio-tags-page.c:427
msgid "<b>Genre:</b>"
msgstr "<b>ປະເພດເພງ:</b>"

#: ../thunar-plugin/audio-tags-page.c:434
msgid "Select or enter the genre of this song here."
msgstr "ເລືອກ ຫຼື ປ້ອນປະເພດຂອງເພງນີ້ທີ່ນີ້."

